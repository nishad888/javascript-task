<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Portfolio Tracker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #00d9ff;
            --secondary: #ff006e;
            --accent: #8338ec;
            --dark: #0a0e27;
            --darker: #05070f;
            --light: #f0f3ff;
            --text: #e0e0e0;
            --muted: #808080;
        }

        body {
            background: linear-gradient(135deg, var(--darker) 0%, #1a1f3a 100%);
            color: var(--text);
            font-family: 'DM Mono', monospace;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Animated background elements */
        .bg-gradient {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 50%, rgba(0, 217, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(255, 0, 110, 0.1) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
            animation: shift 15s ease-in-out infinite;
        }

        @keyframes shift {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .container {
            position: relative;
            z-index: 1;
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header */
        header {
            margin-bottom: 60px;
            animation: slideDown 0.8s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .logo {
            font-size: 2.5em;
            font-weight: 700;
            font-family: 'Space Mono', monospace;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 2px;
        }

        .header-stats {
            display: flex;
            gap: 40px;
        }

        .stat-item {
            text-align: right;
        }

        .stat-label {
            font-size: 0.85em;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 1.8em;
            font-weight: 700;
            color: var(--primary);
            font-family: 'Space Mono', monospace;
        }

        /* Main grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        /* Glass card */
        .card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 32px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            animation: cardEnter 0.6s ease-out backwards;
        }

        @keyframes cardEnter {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card:nth-child(1) { animation-delay: 0.1s; }
        .card:nth-child(2) { animation-delay: 0.2s; }
        .card:nth-child(3) { animation-delay: 0.3s; }
        .card:nth-child(4) { animation-delay: 0.4s; }

        .card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(135deg, transparent 0%, rgba(0, 217, 255, 0.1) 50%, transparent 100%);
            animation: shimmer 3s infinite;
            pointer-events: none;
        }

        @keyframes shimmer {
            0% { transform: translate(-100%, -100%) rotate(45deg); }
            100% { transform: translate(100%, 100%) rotate(45deg); }
        }

        .card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(0, 217, 255, 0.3);
            transform: translateY(-8px);
        }

        .card > * {
            position: relative;
            z-index: 2;
        }

        /* Crypto asset card */
        .asset-card {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .asset-info {
            flex: 1;
        }

        .asset-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2em;
            margin-bottom: 12px;
            color: var(--dark);
        }

        .asset-name {
            font-size: 1.1em;
            font-weight: 600;
            margin-bottom: 4px;
            font-family: 'Space Mono', monospace;
        }

        .asset-symbol {
            font-size: 0.85em;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .asset-price {
            text-align: right;
        }

        .price {
            font-size: 1.6em;
            font-weight: 700;
            margin-bottom: 8px;
            font-family: 'Space Mono', monospace;
        }

        .change {
            font-size: 0.9em;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
            width: fit-content;
            margin-left: auto;
        }

        .change.positive {
            color: #00ff88;
            background: rgba(0, 255, 136, 0.1);
        }

        .change.negative {
            color: #ff3333;
            background: rgba(255, 51, 51, 0.1);
        }

        /* Portfolio section */
        .portfolio-section {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 40px;
            margin-bottom: 40px;
            animation: cardEnter 0.6s ease-out 0.5s backwards;
        }

        .section-title {
            font-size: 1.6em;
            font-weight: 700;
            margin-bottom: 30px;
            font-family: 'Space Mono', monospace;
            color: var(--light);
        }

        /* Portfolio bars */
        .portfolio-item {
            margin-bottom: 24px;
        }

        .portfolio-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 0.95em;
        }

        .portfolio-name {
            font-weight: 600;
            color: var(--light);
        }

        .portfolio-value {
            color: var(--primary);
            font-weight: 700;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            border-radius: 10px;
            animation: fillProgress 1s ease-out forwards;
        }

        @keyframes fillProgress {
            from { width: 0%; }
        }

        .progress-fill:nth-child(1) { animation-delay: 0.6s; }
        .progress-fill:nth-child(2) { animation-delay: 0.7s; }
        .progress-fill:nth-child(3) { animation-delay: 0.8s; }

        /* Interactive elements */
        .input-group {
            display: flex;
            gap: 12px;
            margin: 20px 0;
            flex-wrap: wrap;
        }

        input {
            flex: 1;
            min-width: 200px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            padding: 12px 16px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.95em;
            transition: all 0.3s ease;
        }

        input::placeholder {
            color: var(--muted);
        }

        input:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--primary);
            box-shadow: 0 0 20px rgba(0, 217, 255, 0.2);
        }

        button {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: var(--dark);
            border: none;
            padding: 12px 32px;
            border-radius: 8px;
            font-weight: 700;
            font-family: 'Space Mono', monospace;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9em;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 217, 255, 0.3);
        }

        button:active {
            transform: translateY(0);
        }

        /* Holdings table */
        .holdings-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .holdings-table thead {
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        }

        .holdings-table th {
            text-align: left;
            padding: 16px;
            color: var(--muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85em;
            letter-spacing: 1px;
        }

        .holdings-table td {
            padding: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text);
        }

        .holdings-table tr:hover {
            background: rgba(0, 217, 255, 0.05);
        }

        /* Chart-like visualization */
        .sparkline {
            display: flex;
            align-items: flex-end;
            gap: 2px;
            height: 40px;
            margin: 16px 0;
        }

        .spark-bar {
            flex: 1;
            background: linear-gradient(180deg, var(--primary), var(--secondary));
            border-radius: 2px;
            min-height: 2px;
            animation: sparkAnimate 0.6s ease-out backwards;
        }

        @keyframes sparkAnimate {
            from {
                height: 0%;
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .spark-bar:nth-child(1) { animation-delay: 0.1s; }
        .spark-bar:nth-child(2) { animation-delay: 0.15s; }
        .spark-bar:nth-child(3) { animation-delay: 0.2s; }
        .spark-bar:nth-child(4) { animation-delay: 0.25s; }
        .spark-bar:nth-child(5) { animation-delay: 0.3s; }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 20px 16px;
            }

            .header-content {
                flex-direction: column;
                gap: 20px;
                align-items: flex-start;
            }

            .header-stats {
                width: 100%;
                flex-direction: column;
                gap: 20px;
            }

            .stat-item {
                text-align: left;
            }

            .logo {
                font-size: 1.8em;
            }

            .grid {
                grid-template-columns: 1fr;
            }

            .holdings-table {
                font-size: 0.85em;
            }

            .holdings-table th,
            .holdings-table td {
                padding: 12px;
            }

            .asset-card {
                flex-direction: column;
            }

            .asset-price {
                text-align: left;
                margin-top: 12px;
            }
        }

        /* Loading animation */
        .pulse {
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        /* Notifications */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(0, 217, 255, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 16px 24px;
            border-radius: 8px;
            backdrop-filter: blur(10px);
            z-index: 1000;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <div class="bg-gradient"></div>

    <div class="container">
        <header>
            <div class="header-content">
                <div class="logo">₿ HODL</div>
                <div class="header-stats">
                    <div class="stat-item">
                        <div class="stat-label">Total Portfolio</div>
                        <div class="stat-value" id="totalValue">$0.00</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-label">Total Gain/Loss</div>
                        <div class="stat-value" id="totalGain">+$0.00</div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Crypto Assets -->
        <div class="grid" id="assetsGrid"></div>

        <!-- Portfolio Overview -->
        <div class="portfolio-section">
            <h2 class="section-title">Portfolio Distribution</h2>
            <div id="portfolioDistribution"></div>
        </div>

        <!-- Holdings -->
        <div class="portfolio-section">
            <h2 class="section-title">Your Holdings</h2>
            
            <div class="input-group">
                <input type="text" id="cryptoInput" placeholder="Bitcoin, Ethereum, Cardano..." />
                <input type="number" id="amountInput" placeholder="Amount (USD)" step="0.01" />
                <button onclick="addHolding()">Add Holding</button>
            </div>

            <table class="holdings-table">
                <thead>
                    <tr>
                        <th>Cryptocurrency</th>
                        <th>Amount (USD)</th>
                        <th>Price Change</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="holdingsTableBody"></tbody>
            </table>
        </div>
    </div>

    <script>
        // Mock crypto data with realistic prices
        const cryptoData = {
            'Bitcoin': { symbol: 'BTC', price: 45320, change: 5.2, icon: '₿' },
            'Ethereum': { symbol: 'ETH', price: 2850, change: 8.3, icon: 'Ξ' },
            'Cardano': { symbol: 'ADA', price: 0.92, change: -2.1, icon: '₳' },
            'Solana': { symbol: 'SOL', price: 112.45, change: 12.5, icon: '◎' },
            'Ripple': { symbol: 'XRP', price: 2.15, change: -1.5, icon: '✕' },
            'Polkadot': { symbol: 'DOT', price: 8.72, change: 3.8, icon: '●' }
        };

        let holdings = [];

        function initDashboard() {
            renderAssets();
            renderPortfolioDistribution();
            updateTotals();
        }

        function renderAssets() {
            const grid = document.getElementById('assetsGrid');
            grid.innerHTML = '';

            Object.entries(cryptoData).slice(0, 4).forEach(([name, data]) => {
                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <div class="asset-card">
                        <div class="asset-info">
                            <div class="asset-icon">${data.icon}</div>
                            <div class="asset-name">${name}</div>
                            <div class="asset-symbol">${data.symbol}</div>
                        </div>
                        <div class="asset-price">
                            <div class="price">$${data.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
                            <div class="change ${data.change >= 0 ? 'positive' : 'negative'}">
                                ${data.change >= 0 ? '↑' : '↓'} ${Math.abs(data.change).toFixed(1)}%
                            </div>
                        </div>
                    </div>
                    <div class="sparkline">
                        ${[...Array(6)].map((_, i) => `<div class="spark-bar" style="height: ${Math.random() * 100}%;"></div>`).join('')}
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function renderPortfolioDistribution() {
            const container = document.getElementById('portfolioDistribution');
            const portfolioData = [
                { name: 'Bitcoin', percentage: 45 },
                { name: 'Ethereum', percentage: 30 },
                { name: 'Altcoins', percentage: 25 }
            ];

            container.innerHTML = portfolioData.map(item => `
                <div class="portfolio-item">
                    <div class="portfolio-header">
                        <span class="portfolio-name">${item.name}</span>
                        <span class="portfolio-value">${item.percentage}%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: ${item.percentage}%;"></div>
                    </div>
                </div>
            `).join('');
        }

        function addHolding() {
            const cryptoInput = document.getElementById('cryptoInput');
            const amountInput = document.getElementById('amountInput');

            const crypto = cryptoInput.value.trim();
            const amount = parseFloat(amountInput.value);

            if (!crypto || !amount || amount <= 0) {
                showNotification('Please enter valid cryptocurrency and amount');
                return;
            }

            holdings.push({
                id: Date.now(),
                name: crypto,
                amount: amount,
                addedDate: new Date().toLocaleDateString()
            });

            cryptoInput.value = '';
            amountInput.value = '';

            renderHoldings();
            updateTotals();
            showNotification(`${crypto} added to portfolio!`);
        }

        function renderHoldings() {
            const tbody = document.getElementById('holdingsTableBody');
            tbody.innerHTML = '';

            holdings.forEach(holding => {
                const row = document.createElement('tr');
                const cryptoInfo = Object.entries(cryptoData).find(([name]) => 
                    name.toLowerCase().includes(holding.name.toLowerCase())
                )?.[1];

                const change = cryptoInfo ? cryptoInfo.change : 0;
                const changeClass = change >= 0 ? 'positive' : 'negative';

                row.innerHTML = `
                    <td>${holding.name}</td>
                    <td>$${holding.amount.toFixed(2)}</td>
                    <td><span class="change ${changeClass}">${change >= 0 ? '↑' : '↓'} ${Math.abs(change).toFixed(1)}%</span></td>
                    <td><button onclick="removeHolding(${holding.id})" style="padding: 6px 12px; font-size: 0.8em;">Remove</button></td>
                `;
                tbody.appendChild(row);
            });
        }

        function removeHolding(id) {
            holdings = holdings.filter(h => h.id !== id);
            renderHoldings();
            updateTotals();
            showNotification('Holding removed');
        }

        function updateTotals() {
            const total = holdings.reduce((sum, h) => sum + h.amount, 0);
            const gain = total * 0.07; // Mock calculation

            document.getElementById('totalValue').textContent = `$${total.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
            document.getElementById('totalGain').textContent = `+$${gain.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
        }

        function showNotification(message) {
            const notif = document.createElement('div');
            notif.className = 'notification';
            notif.textContent = message;
            document.body.appendChild(notif);

            setTimeout(() => {
                notif.remove();
            }, 3000);
        }

        // Initialize on load
        window.addEventListener('load', initDashboard);
    </script>
</body>
</html>